# =============================================================================
# Autonomous BingX Trading System — environment template
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# NEVER commit real keys. The system runs in DRY-RUN (paper) mode by default;
# the exchange keys below are only used for *read* access to live market data
# and are not required to flip to live trading (there is no auto-live path).
# =============================================================================

# --- BingX exchange (spot) -------------------------------------------------
# Read-only / market-data keys are sufficient for dry-run. Generate keys in
# the BingX web UI (API Management). Leave blank to use public data only.
# Freqtrade picks these up automatically via the FREQTRADE__ override syntax,
# so they merge into config.json -> exchange.key / exchange.secret.
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=

# --- Freqtrade REST API / FreqUI -------------------------------------------
# Used by FreqUI, the watchdog kill-switch, and the optional dashboard.
# The FREQTRADE__ vars are consumed directly by the freqtrade container;
# the plain vars are consumed by the watchdog / dashboard clients.
FREQTRADE_API_URL=http://freqtrade:8080
FREQTRADE_USERNAME=freqtrader
FREQTRADE_PASSWORD=change_me_please
FREQTRADE__API_SERVER__USERNAME=freqtrader
FREQTRADE__API_SERVER__PASSWORD=change_me_please
# JWT secret + ws token for the Freqtrade REST server (generate random strings)
FREQTRADE__API_SERVER__JWT_SECRET_KEY=change_me_random_string
FREQTRADE__API_SERVER__WS_TOKEN=change_me_random_token

# --- Telegram (alerts + control) -------------------------------------------
# Create a bot via @BotFather; chat_id from @userinfobot. Optional but
# recommended — the watchdog and heartbeat send alerts here.
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
# Consumed directly by the freqtrade container (merged into config.json):
FREQTRADE__TELEGRAM__ENABLED=false
FREQTRADE__TELEGRAM__TOKEN=
FREQTRADE__TELEGRAM__CHAT_ID=

# --- Anthropic (LLM research sidecar) --------------------------------------
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8
# Thinking depth for the market-context classifier: low | medium | high | max.
# Higher = more reasoning (and more cost/latency) per cycle. Default medium.
LLM_EFFORT=medium

# --- Postgres / TimescaleDB ------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=change_me_please
# Convenience DSN built from the above (used by sidecar/watchdog).
DATABASE_URL=postgresql://trading:change_me_please@postgres:5432/trading

# --- News sources for the sidecar ------------------------------------------
# Comma-separated RSS feed URLs (free). Defaults are set in research/sidecar.py.
NEWS_RSS_FEEDS=

# --- Risk limits (paper). Percentages are of TOTAL_CAPITAL_USDT. ------------
# These mirror the values baked into user_data/config.json + risk/watchdog.
TOTAL_CAPITAL_USDT=1000
PER_TRADE_STAKE_USDT=100
MAX_OPEN_TRADES=3
DAILY_MAX_LOSS_PCT=5
MAX_DRAWDOWN_PCT=10

# --- Sidecar scheduling -----------------------------------------------------
SIDECAR_INTERVAL_SECONDS=120
# Self-improvement analyst agent: how often it reviews trade outcomes (daily by
# default) and the minimum closed trades before it bothers reviewing.
ANALYST_INTERVAL_SECONDS=86400
ANALYST_MIN_TRADES=20

# --- Watchdog scheduling ----------------------------------------------------
WATCHDOG_INTERVAL_SECONDS=30

# =============================================================================
# LIVE browser-execution path (REAL MONEY). OFF by default.
# -----------------------------------------------------------------------------
# When enabled, the browser subagent places REAL orders on the live BingX web
# UI. These orders are NOT visible to the Freqtrade watchdog; the independent
# live watchdog + the gate in execution_logic are the safety layer. Read
# docs/BROWSER_EXECUTION.md before turning this on. Spot only, no leverage.
# =============================================================================

# Master switch. Leave OFF until you have read the docs and logged in once.
# Turning this on is your deliberate go-live act.
LIVE_BROWSER_TRADING_ENABLED=false

# Only these pairs may ever be traded on the live path (independent allowlist).
LIVE_PAIR_ALLOWLIST=BTC/USDT,ETH/USDT,SOL/USDT

# Order path: api | browser | both. "both" = API first, browser fallback on
# API failure. Account reads always use the API. The API keys come from the
# FREQTRADE__EXCHANGE__KEY / FREQTRADE__EXCHANGE__SECRET vars above.
ORDER_PATH=both
POSITION_DUST_USDT=1.0

# Optional shared secret for the Freqtrade->bridge webhook. Leave blank when the
# bridge is only reachable on the internal docker network (default).
EXECUTION_WEBHOOK_TOKEN=

# Browser subagent
BROWSER_HEADLESS=true
BROWSER_PROFILE_DIR=/data/bingx-profile   # persistent Chrome profile (login once)
BROWSER_AUDIT_DIR=/data/audit             # screenshots of every order attempt
BROWSER_POLL_SECONDS=2

# Live account watchdog
LIVE_WATCHDOG_INTERVAL_SECONDS=30
WATCHDOG_FLATTEN_ON_BREACH=true

# --- Dashboard login (REQUIRED when running on a public VPS / subdomain) -----
# One password gates the whole dashboard (and the TURN ON / STOP controls).
# Leave blank only for local-only use. Pick a long, unique password.
DASHBOARD_PASSWORD=
# Optional: keeps you logged in across restarts (any long random string).
DASHBOARD_COOKIE_SECRET=

# --- Public subdomain (for the caddy "public" profile) ----------------------
# The domain that should serve the dashboard over HTTPS. Point its DNS A record
# at this server first. Caddy gets/renews the TLS certificate automatically.
DASHBOARD_DOMAIN=trade.ohmycompany.ai
